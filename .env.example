# Agent Vision — Environment Configuration
# Copy this file to .env and fill in values.

# OCR backend: "paddleocr" (cloud) or "tesseract" (offline)
OCR_BACKEND=paddleocr

# PaddleOCR Cloud API (required if OCR_BACKEND=paddleocr)
PADDLEOCR_DOC_PARSING_API_URL=https://your-api.paddleocr.com/layout-parsing
PADDLEOCR_ACCESS_TOKEN=your_access_token_here
PADDLEOCR_DOC_PARSING_TIMEOUT=600

# Tesseract settings (used if OCR_BACKEND=tesseract)
TESSERACT_LANG=chi_tra+eng  # or chi_sim+eng, eng only, etc.
